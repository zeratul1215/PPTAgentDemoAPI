{
  "name": "PPTAgentDemoAPI",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "secrets": {
    "GEMINI_API_KEY": {}
  },
  "containerEnv": {
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}"
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI",
      "onAutoForward": "notify"
    }
  }
}
